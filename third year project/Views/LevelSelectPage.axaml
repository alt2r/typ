<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
              x:Class="third_year_project.Views.LevelSelectPage"
			xmlns:vm="clr-namespace:third_year_project.ViewModels"
			x:DataType="vm:LevelSelectViewModel"
			Background="{StaticResource BlueBrush}">

		<Grid RowDefinitions="2*,5*,2*" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
			<Border Grid.Row="0" Width="220" Margin="10">

				<TextBlock Text="Level Select page" FontSize="20" HorizontalAlignment="Center"  Grid.Row="0"
						   VerticalAlignment="Center" Foreground="{StaticResource BlackBrush}"/>
			</Border>
			<StackPanel Orientation="Horizontal" Spacing="10" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
				<StackPanel Orientation="Vertical">
					<TextBlock Text="bohemian rhapsody" FontSize="12" HorizontalAlignment="Center"/>
			<Button	 Height="40" Width="80" HorizontalAlignment="Center"
					HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Content="Level 1"
					Command="{Binding LevelClick}" CommandParameter="1" Grid.Row="1" Grid.Column="1" Margin="5"/>
				</StackPanel>
				<StackPanel Orientation="Vertical">
					<TextBlock Text="critical acclaim" FontSize="12" HorizontalAlignment="Center"/>
			<Button	Height="40" Width="80" Margin="5"
					HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" Content="Level 2"
					Command="{Binding LevelClick}" CommandParameter="2" Grid.Row="1" Grid.Column="1"/>
					</StackPanel>
				<StackPanel Orientation="Vertical">
					<TextBlock Text="saving hope" FontSize="12" HorizontalAlignment="Center"/>
			<Button Height="40" Width="80" HorizontalContentAlignment="Center"
					VerticalContentAlignment="Bottom" Content="Level 3"
					Command="{Binding LevelClick}" CommandParameter="3"
					Grid.Row="1" Grid.Column="1" Margin="5"/>
					</StackPanel>
				<StackPanel Orientation="Vertical">
					<TextBlock Text="testing rhythm" FontSize="12" HorizontalAlignment="Center"/>
			<Button	Height="40" Width="80" HorizontalContentAlignment="Center"
					VerticalContentAlignment="Bottom" Content="Level 4"
					Command="{Binding LevelClick}" CommandParameter="4"
					Grid.Row="1" Grid.Column="1" Margin="5"/>
					</StackPanel>
				<StackPanel Orientation="Vertical">
					<TextBlock Text="monomyth" FontSize="12" HorizontalAlignment="Center"/>
			<Button	Height="40" Width="80" HorizontalContentAlignment="Center"
					VerticalContentAlignment="Bottom" Content="Level 5"
					Command="{Binding LevelClick}" CommandParameter="5"
					Grid.Row="1" Grid.Column="1" Margin="5"/>
					</StackPanel>
			</StackPanel>

			<Button
				HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
				Content="Back to homepage" Command="{Binding HomeClick}"
				HorizontalAlignment="Left" Width="150" Height="40" Grid.Row="3" Margin="10"/>
		</Grid>
</UserControl>
