<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="third_year_project.Views.LearnPage"
			xmlns:vm="clr-namespace:third_year_project.ViewModels"
			x:DataType="vm:LearnPageViewModel"
			 Background="{StaticResource BlueBrush}">
	

		<Grid RowDefinitions="1*,4*,1*,1*">
			<Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="3" Background="{StaticResource AccentBrush1}" Grid.Row="0" Width="300" Margin="10">
				<TextBlock Text="Learn From Visualisations" FontSize="20" HorizontalAlignment="Center" TextAlignment="Center" Padding="10" VerticalAlignment="Center"
						   FontFamily="{StaticResource PrimaryFontFamily}" Foreground="{StaticResource BlackBrush}"/>
			</Border>
			<Grid Grid.Row="1" Background="{StaticResource SecondaryBrush1}" HorizontalAlignment="Stretch" ColumnDefinitions="1*,8*,1*">
				<StackPanel Grid.Column="0">
					<TextBlock Text="Outer/Left:" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Padding="5"
							FontFamily="{StaticResource PrimaryFontFamily}" Name="LeftTopDiagramDesc"/>	
					<TextBlock Text="Note: 4 4" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Padding="5"
							FontFamily="{StaticResource PrimaryFontFamily}" Name="LeftBottomDiagramDesc"/>
					
				</StackPanel>
			<ContentControl Content="{Binding CurrentDiagram}" Grid.Column="1"
							HorizontalAlignment="Center" VerticalAlignment="Stretch" />
				<StackPanel Grid.Column="2">
					<TextBlock Text="Inner/Right:" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Padding="5"
							FontFamily="{StaticResource PrimaryFontFamily}" Name="RightTopDiagramDesc"/>
					<TextBlock Text="Note: 4 4 3 3" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Padding="5"
							FontFamily="{StaticResource PrimaryFontFamily}" Name="RightBottomDiagramDesc"/>
				</StackPanel>
			</Grid>

			<Grid Margin="20" Grid.Row="2" ColumnDefinitions="1*, 1*, 1*">
				<Border Grid.Column="0" Width="100" HorizontalAlignment="Right" Height="50" Margin="0, 0, 10, 0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
					<TextBlock Text="BPM: " HorizontalAlignment="Center" Background="{StaticResource LightBlueBrush}" FontSize="18"
							   Foreground="{StaticResource BlackBrush}"/>
					<TextBlock Text="{Binding #bpmSlider.Value}" FontSize="18" Foreground="{StaticResource BlackBrush}"
								HorizontalAlignment="Center"  Background="{StaticResource LightBlueBrush}"/>
				</StackPanel>
				</Border>
				<Slider x:Name="bpmSlider" Grid.Column="1"
						Minimum="40" Maximum="200" TickFrequency="5"
						IsSnapToTickEnabled="True" Value="{Binding BpmSliderValue, Mode=TwoWay}"
						BorderBrush="{StaticResource WhiteBrush}" BorderThickness="2"
						Height="50" Foreground="{StaticResource BlackBrush}"/>
			</Grid>
			
				<Button HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
					Grid.Row="3" Margin="5" Width="150" Height="40"
					Content="Switch Control" Command="{Binding SwitchCommand}"/>

			<Button
				HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
				Content="Back to homepage" Command="{Binding HomeClick}"
				HorizontalAlignment="Left" Width="150" Height="40" Grid.Row="3" Margin="10"/>

			<Button Grid.Row="3" HorizontalAlignment="Right" Content="Practice This!" Margin="10"
					Width="150" HorizontalContentAlignment="Center" Height="60" 
					VerticalContentAlignment="Center" Command="{Binding PracticeClick}"/>

		</Grid>
</UserControl>


